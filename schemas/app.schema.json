{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/app-validation-spec/app-validation-spec/schemas/app.schema.json",
  "title": "App Package",
  "description": "Schema for app.json — the canonical manifest of an App Package in the automated app validation system.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specVersion",
    "appId",
    "status",
    "identity",
    "audience",
    "commerce",
    "landingPage"
  ],
  "properties": {
    "specVersion": {
      "type": "string",
      "description": "Semver of the App Package Specification this file conforms to.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "appId": {
      "type": "string",
      "description": "Stable kebab-case identifier. Used for Drive folder name, URLs, and analytics. Never rename after first deploy.",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 64,
      "examples": ["focus-timer-pro"]
    },
    "status": {
      "type": "string",
      "description": "Lifecycle state of the app package in the validation pipeline.",
      "enum": ["draft", "provisioning", "ready", "validating", "paused", "winner", "killed", "built"]
    },
    "identity": { "$ref": "#/$defs/identity" },
    "audience": { "$ref": "#/$defs/audience" },
    "commerce": { "$ref": "#/$defs/commerce" },
    "branding": { "$ref": "#/$defs/branding" },
    "mockup": { "$ref": "#/$defs/mockup" },
    "media": { "$ref": "#/$defs/media" },
    "landingPage": { "$ref": "#/$defs/landingPage" },
    "ads": { "$ref": "#/$defs/ads" },
    "tracking": { "$ref": "#/$defs/tracking" },
    "analytics": { "$ref": "#/$defs/analytics" },
    "experiment": { "$ref": "#/$defs/experiment" },
    "source": { "$ref": "#/$defs/source" },
    "deployment": { "$ref": "#/$defs/deployment" },
    "appStore": { "$ref": "#/$defs/appStore" }
  },
  "$defs": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["appName", "description", "category", "platform"],
      "properties": {
        "appName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "description": "Display name of the app."
        },
        "tagline": {
          "type": "string",
          "maxLength": 120,
          "description": "Short hook shown in hero sections and ads."
        },
        "badgeText": {
          "type": "string",
          "maxLength": 80,
          "description": "Optional hero badge label, e.g. Coming soon to the App Store. Landing generators may fall back to platform-based defaults when omitted."
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "One-paragraph summary of what the app does."
        },
        "category": {
          "type": "string",
          "enum": [
            "productivity",
            "health-fitness",
            "finance",
            "education",
            "entertainment",
            "social",
            "utilities",
            "lifestyle",
            "business",
            "developer-tools",
            "other"
          ],
          "description": "Primary app category. Use categoryLabel when category is other."
        },
        "categoryLabel": {
          "type": "string",
          "maxLength": 60,
          "description": "Free-text category when category is other."
        },
        "platform": {
          "type": "string",
          "enum": ["ios", "android", "web", "cross-platform"],
          "description": "Target platform for the app idea."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 40 },
          "maxItems": 20,
          "uniqueItems": true,
          "description": "Optional discovery and filtering tags."
        }
      },
      "if": {
        "properties": { "category": { "const": "other" } },
        "required": ["category"]
      },
      "then": {
        "required": ["categoryLabel"]
      }
    },
    "audience": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 5,
          "maxLength": 300,
          "description": "Primary target audience description."
        },
        "landingPhrase": {
          "type": "string",
          "minLength": 5,
          "maxLength": 120,
          "description": "Short audience phrase for landing pages, e.g. Built for {landingPhrase}. Falls back to primary when omitted."
        },
        "secondary": {
          "type": "string",
          "maxLength": 300,
          "description": "Optional secondary audience."
        },
        "painPoints": {
          "type": "array",
          "items": { "type": "string", "minLength": 5, "maxLength": 200 },
          "minItems": 1,
          "maxItems": 10,
          "description": "Problems the app solves for the audience."
        },
        "personas": {
          "type": "array",
          "items": { "$ref": "#/$defs/persona" },
          "maxItems": 5
        }
      }
    },
    "persona": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "summary"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 60 },
        "summary": { "type": "string", "minLength": 10, "maxLength": 300 }
      }
    },
    "commerce": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pricing", "cta"],
      "properties": {
        "pricing": { "$ref": "#/$defs/pricing" },
        "cta": { "$ref": "#/$defs/cta" }
      }
    },
    "pricing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model"],
      "properties": {
        "model": {
          "type": "string",
          "enum": ["free", "freemium", "paid", "subscription"]
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "ISO 4217 currency code.",
          "examples": ["USD"]
        },
        "amount": {
          "type": "number",
          "minimum": 0,
          "description": "Price amount. Use 0 for free apps."
        },
        "period": {
          "type": "string",
          "enum": ["one-time", "monthly", "yearly"],
          "description": "Billing period for subscription or paid models."
        },
        "trialDays": {
          "type": "integer",
          "minimum": 0,
          "maximum": 365
        },
        "headlineLabel": {
          "type": "string",
          "maxLength": 40,
          "description": "Pricing section label before the price amount, e.g. Get for."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "model": { "enum": ["paid", "subscription", "freemium"] } },
            "required": ["model"]
          },
          "then": { "required": ["currency", "amount"] }
        },
        {
          "if": {
            "properties": { "model": { "const": "subscription" } },
            "required": ["model"]
          },
          "then": { "required": ["period"] }
        }
      ]
    },
    "cta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryText", "buyNowText"],
      "properties": {
        "primaryText": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40,
          "description": "Main call-to-action button label."
        },
        "secondaryText": {
          "type": "string",
          "maxLength": 40,
          "description": "Secondary action label, e.g. Learn More."
        },
        "buyNowText": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40,
          "description": "Label for purchase-intent actions on the landing page."
        },
        "waitlistText": {
          "type": "string",
          "maxLength": 40,
          "description": "Label for waitlist or early-access signup."
        },
        "emailPlaceholder": {
          "type": "string",
          "maxLength": 60,
          "description": "Placeholder text for email capture input. Prefer landingPage.sections[cta].inline.placeholder when using inline CTA copy."
        }
      }
    },
    "branding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["theme", "style"],
      "properties": {
        "theme": { "$ref": "#/$defs/theme" },
        "style": { "$ref": "#/$defs/style" }
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "primaryColor"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["light", "dark", "auto"]
        },
        "landingStyle": {
          "type": "string",
          "enum": [
            "liquid-glass",
            "apple-light",
            "apple-dark",
            "midnight",
            "aurora",
            "black-titanium",
            "minimal-white"
          ],
          "description": "Landing page theme preset. Falls back from mode when omitted."
        },
        "primaryColor": {
          "type": "string",
          "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{3})$"
        },
        "accentColor": {
          "type": "string",
          "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{3})$"
        },
        "accentName": {
          "type": "string",
          "enum": ["violet", "blue", "emerald", "rose", "amber", "cyan"],
          "description": "Landing template accent palette name. Preferred over accentColor hex mapping when set."
        },
        "fontFamily": {
          "type": "string",
          "maxLength": 100
        }
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tone"],
      "properties": {
        "tone": {
          "type": "string",
          "enum": ["professional", "playful", "minimal", "bold", "custom"]
        },
        "styleNotes": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "mockup": {
      "type": "object",
      "additionalProperties": false,
      "description": "Source project info for building the interactive mockup and deployed preview info after automation runs.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["static", "prototype", "interactive"],
          "description": "Mockup fidelity level."
        },
        "sourcePath": {
          "type": "string",
          "description": "Path to mockup source relative to package root, e.g. mockup/."
        },
        "framework": {
          "type": "string",
          "maxLength": 60,
          "description": "Framework or toolchain, e.g. react, vue, html-static."
        },
        "entryPoint": {
          "type": "string",
          "description": "Entry file relative to package root, e.g. mockup/index.html."
        },
        "installCommand": {
          "type": "string",
          "maxLength": 200,
          "description": "Shell command to install mockup dependencies, e.g. npm install."
        },
        "buildCommand": {
          "type": "string",
          "maxLength": 200,
          "description": "Shell command to build the mockup before deploy."
        },
        "devCommand": {
          "type": "string",
          "maxLength": 200,
          "description": "Shell command to run the mockup locally for preview."
        },
        "deployCommand": {
          "type": "string",
          "maxLength": 200,
          "description": "Shell command to deploy the built mockup."
        },
        "previewUrl": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "Live preview URL after mockup deploy. Null until deployed."
        },
        "baseWidth": {
          "type": "integer",
          "minimum": 200,
          "maximum": 1200,
          "description": "Mockup iframe base width in pixels for landing embed."
        },
        "baseHeight": {
          "type": "integer",
          "minimum": 200,
          "maximum": 2000,
          "description": "Mockup iframe base height in pixels for landing embed."
        },
        "clipBottomPx": {
          "type": "integer",
          "minimum": 0,
          "maximum": 500,
          "description": "Pixels clipped from mockup iframe bottom to hide dev chrome."
        },
        "useOuterDeviceFrame": {
          "type": "boolean",
          "description": "Whether the landing embed shows an outer device frame."
        },
        "notes": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "mediaAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Path relative to package root."
        },
        "alt": { "type": "string", "maxLength": 200 },
        "title": {
          "type": "string",
          "maxLength": 80,
          "description": "Optional caption title, commonly used for screenshots."
        },
        "description": {
          "type": "string",
          "maxLength": 200,
          "description": "Optional caption description, commonly used for screenshots."
        },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "icon": { "$ref": "#/$defs/mediaAsset" },
        "logo": { "$ref": "#/$defs/mediaAsset" },
        "ogImage": { "$ref": "#/$defs/mediaAsset" },
        "screenshots": {
          "type": "array",
          "items": { "$ref": "#/$defs/mediaAsset" },
          "maxItems": 10
        },
        "demoVideo": { "$ref": "#/$defs/mediaAsset" }
      }
    },
    "landingPageSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "enabled", "source"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["hero", "features", "screenshots", "socialProof", "pricing", "faq", "cta", "footer"]
        },
        "enabled": { "type": "boolean" },
        "source": {
          "type": "string",
          "enum": ["inline", "file", "media"],
          "description": "inline: copy in section object; file: markdown path; media: pull from media.screenshots."
        },
        "inline": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "headline": { "type": "string", "maxLength": 120 },
            "subheadline": { "type": "string", "maxLength": 300 },
            "body": { "type": "string", "maxLength": 2000 },
            "placeholder": {
              "type": "string",
              "maxLength": 60,
              "description": "Email input placeholder when section id is cta."
            }
          }
        },
        "file": {
          "type": "string",
          "description": "Path to markdown copy file relative to package root."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "source": { "const": "inline" }, "enabled": { "const": true } },
            "required": ["source", "enabled"]
          },
          "then": { "required": ["inline"] }
        },
        {
          "if": {
            "properties": { "source": { "const": "file" }, "enabled": { "const": true } },
            "required": ["source", "enabled"]
          },
          "then": { "required": ["file"] }
        }
      ]
    },
    "landingPage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sections"],
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
          "description": "URL slug for the landing page. Defaults to appId when omitted."
        },
        "sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/landingPageSection" },
          "minItems": 1
        },
        "seo": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title": { "type": "string", "maxLength": 70 },
            "description": { "type": "string", "maxLength": 160 },
            "keywords": {
              "type": "array",
              "items": { "type": "string", "minLength": 1, "maxLength": 40 },
              "maxItems": 15
            }
          }
        }
      }
    },
    "ads": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "campaignName": { "type": "string", "maxLength": 100 },
        "objective": {
          "type": "string",
          "enum": ["awareness", "traffic", "conversions", "leads", "app-installs"]
        },
        "headlines": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 40 },
          "maxItems": 5
        },
        "primaryTexts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 125 },
          "maxItems": 5
        },
        "descriptions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 90 },
          "maxItems": 5
        },
        "callToAction": {
          "type": "string",
          "enum": [
            "LEARN_MORE",
            "SHOP_NOW",
            "SIGN_UP",
            "DOWNLOAD",
            "GET_OFFER",
            "SUBSCRIBE"
          ]
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["facebook", "instagram", "google", "tiktok", "twitter", "linkedin"]
          },
          "minItems": 1,
          "maxItems": 6,
          "uniqueItems": true,
          "description": "Paid social or ad platforms for this campaign."
        },
        "utmTemplate": {
          "description": "UTM parameters for campaign links. Prefer the structured object form.",
          "oneOf": [
            {
              "type": "string",
              "maxLength": 500,
              "description": "Legacy query string form, e.g. utm_source=facebook&utm_campaign={{appId}}."
            },
            { "$ref": "#/$defs/utmTemplateObject" }
          ]
        }
      }
    },
    "utmTemplateObject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "maxLength": 50,
          "description": "utm_source value. May use {{appId}} placeholder."
        },
        "medium": {
          "type": "string",
          "maxLength": 50,
          "description": "utm_medium value."
        },
        "campaign": {
          "type": "string",
          "maxLength": 100,
          "description": "utm_campaign value. May use {{appId}} placeholder."
        },
        "content": {
          "type": "string",
          "maxLength": 100,
          "description": "Optional utm_content value."
        },
        "term": {
          "type": "string",
          "maxLength": 100,
          "description": "Optional utm_term value."
        }
      }
    },
    "tracking": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "webhookUrl": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "Canonical unified landing-event webhook. Required before status becomes ready."
        },
        "webhooks": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "validationComplete": { "type": ["string", "null"], "format": "uri" },
            "deployComplete": { "type": ["string", "null"], "format": "uri" },
            "emailCaptured": { "type": ["string", "null"], "format": "uri" },
            "buyNowClicked": { "type": ["string", "null"], "format": "uri" }
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
              "description": { "type": "string", "maxLength": 200 }
            }
          },
          "maxItems": 20
        }
      }
    },
    "analytics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "projectId": { "type": "string", "maxLength": 100 },
        "experimentId": { "type": "string", "maxLength": 100 },
        "experimentRunId": {
          "type": "string",
          "maxLength": 100,
          "description": "Immutable run identifier for one validation cycle."
        },
        "landingVariantId": {
          "type": "string",
          "maxLength": 40,
          "description": "Landing page copy/layout variant identifier."
        },
        "mockupVersionId": {
          "type": "string",
          "maxLength": 40,
          "description": "Mockup build variant identifier."
        },
        "funnelName": { "type": "string", "maxLength": 100 },
        "customDimensions": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "experiment": {
      "type": "object",
      "additionalProperties": false,
      "description": "Validation experiment definition — hypothesis, budget, and decision rules for the automated test.",
      "properties": {
        "experimentName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Human-readable name for this validation run."
        },
        "hypothesis": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "What you believe will happen and why."
        },
        "successCriteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 5, "maxLength": 200 },
          "minItems": 1,
          "maxItems": 10,
          "description": "Measurable outcomes that define experiment success."
        },
        "testBudget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$"
            },
            "amount": {
              "type": "number",
              "minimum": 0
            },
            "durationDays": {
              "type": "integer",
              "minimum": 1,
              "maximum": 90
            }
          },
          "required": ["currency", "amount", "durationDays"]
        },
        "decisionRules": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "winnerThreshold": {
              "type": "string",
              "maxLength": 200,
              "description": "Rule for promoting an app to winner status."
            },
            "killThreshold": {
              "type": "string",
              "maxLength": 200,
              "description": "Rule for killing an underperforming experiment."
            },
            "minSampleSize": {
              "type": "integer",
              "minimum": 1,
              "description": "Minimum events or visitors before a decision."
            },
            "notes": {
              "type": "string",
              "maxLength": 500
            }
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "description": "Pre-provisioned deploy infrastructure metadata. Human-set at package setup; read by WF1; never written by automation.",
      "properties": {
        "mockupGithubRepo": {
          "type": "string",
          "minLength": 3,
          "maxLength": 200,
          "description": "GitHub repository for mockup deploys, as org/repo (e.g. scootero/Human-Lab) or full GitHub URL."
        },
        "mockupBranch": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Git branch Vercel should deploy from (e.g. main)."
        },
        "mockupRootDirectory": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Root directory within the GitHub repo for the mockup app (e.g. mockup). Must match Vercel project settings."
        },
        "vercelMockupProjectId": {
          "type": ["string", "null"],
          "maxLength": 100,
          "description": "Vercel project ID for the mockup (e.g. prj_xxx). At least one of vercelMockupProjectId or vercelMockupProjectName required before WF1."
        },
        "vercelMockupProjectName": {
          "type": ["string", "null"],
          "maxLength": 100,
          "description": "Vercel project name for the mockup. At least one of vercelMockupProjectId or vercelMockupProjectName required before WF1."
        }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "description": "Generated and deployed URLs and platform IDs. Populated by automation; null until deploy steps complete.",
      "properties": {
        "mockup": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "vercelProjectId": { "type": ["string", "null"], "maxLength": 100 },
            "url": { "type": ["string", "null"], "format": "uri" },
            "lastDeployedAt": {
              "type": ["string", "null"],
              "format": "date-time",
              "description": "ISO 8601 timestamp of the most recent mockup deploy."
            }
          }
        },
        "landing": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "vercelProjectId": { "type": ["string", "null"], "maxLength": 100 },
            "url": {
              "type": ["string", "null"],
              "format": "uri",
              "description": "Canonical public landing page URL (ad destination)."
            },
            "deploymentUrl": {
              "type": ["string", "null"],
              "format": "uri",
              "description": "Latest Vercel deployment URL for the landing page."
            },
            "lastDeployedAt": {
              "type": ["string", "null"],
              "format": "date-time",
              "description": "ISO 8601 timestamp of the most recent landing deploy."
