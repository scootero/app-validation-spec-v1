          }
        },
        "githubRepoUrl": { "type": ["string", "null"], "format": "uri" }
      }
    },
    "appStore": {
      "type": "object",
      "additionalProperties": false,
      "description": "Reserved for future App Store metadata. Optional in Phase 1.",
      "properties": {
